[Unit]
Description=Oasis Discord Bot
After=network.target

[Service]
Type=simple
User=administrator
Group=administrator
WorkingDirectory=/home/administrator/oasis
ExecStart=/home/administrator/oasis/venv/bin/python src/main.py
Restart=always
RestartSec=5
EnvironmentFile=/home/administrator/oasis/.env
StandardOutput=append:/home/administrator/oasis/logs/bot.log
StandardError=append:/home/administrator/oasis/logs/error.log

[Install]
WantedBy=multi-user.target
